NODE_ENV=development
SITE_URL=http://localhost:8888

# Base de datos Postgres/Neon
# Configurar manualmente con la connection string de la base usada por el sitio.
NETLIFY_DATABASE_URL=

# Admin auth
ADMIN_EMAIL=admin@prons.com.ar
ADMIN_USER=admin
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=

# Email provider (Resend o compatible)
RESEND_API_KEY=
EMAIL_FROM=Prons Seguridad <no-reply@prons.com.ar>

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v23.0
WHATSAPP_APP_SECRET=
WHATSAPP_TEMPLATE_LANG=es_AR
WHATSAPP_TEMPLATE_FORM_SUBMITTED=
WHATSAPP_TEMPLATE_FORM_SUBMITTED_HEADER_IMAGE=
WHATSAPP_TEMPLATE_FORM_SUBMITTED_DISABLE_BODY=false
WHATSAPP_TEMPLATE_REMINDER=
WHATSAPP_TEMPLATE_REMINDER_HEADER_IMAGE=
WHATSAPP_TEMPLATE_REMINDER_DISABLE_BODY=false
