NODE_ENV=development
SITE_URL=http://localhost:8888

# Netlify DB
# Local: se completa al correr `npx netlify db init` o al vincular el sitio y usar `npx netlify dev`
NETLIFY_DATABASE_URL=

# Admin auth
ADMIN_EMAIL=admin@prons.com.ar
ADMIN_USER=admin
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=

# Email provider (Resend o compatible)
RESEND_API_KEY=
EMAIL_FROM=Prons Seguridad <no-reply@prons.com.ar>

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_LANG=es_AR
WHATSAPP_TEMPLATE_FORM_SUBMITTED=
WHATSAPP_TEMPLATE_REMINDER=
